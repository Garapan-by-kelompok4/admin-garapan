# Development — copy to .env.local

# Admin app origin (browser-facing). Keep Next on :3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NestJS API base — SERVER-ONLY. Called by the BFF Route Handlers, never the
# browser. No global prefix and no trailing slash (controllers live at
# /auth/* and /admin/*).
#
# For local dev you can point this at the deployed backend on url (ask the team
# for the URL) so you don't have to run NestJS locally — but that is the LIVE
# backend shared with the mobile app, so destructive admin actions (ban, dispute
# resolve) mutate real data. For that kind of testing, run the backend locally:
#   NESTJS_API_URL=http://localhost:3001
NESTJS_API_URL=https://your-backend.up.url
